# The Dockerfile only COPYs Package.swift, Package.resolved, Sources,
# Tests, and heidrun-server.example.toml — everything else here is
# belt-and-suspenders to keep the build context small and reproducible.
#
# Tests/ is intentionally NOT excluded: SPM parses the .testTarget
# declaration in Package.swift even when we only build the executable
# product, and bails out with "overlapping sources" if it can't find
# Tests/HeidrunServerKitTests/ at the declared path.

# .git is intentionally NOT excluded — the `git-info` build stage
# reads it to auto-stamp the binary with the short SHA + ISO date
# surfaced through `/version` and the bootstrap admin log line. The
# build context cost is modest (a small repo) and the `git-info`
# stage is the only consumer; the main Swift build stage's COPYs
# are explicit and don't pull in `.git`.
.gitignore
.github

.build
.swiftpm
*.xcodeproj
*.xcworkspace
DerivedData

deploy
README.md
docker-compose.yml
Dockerfile
.dockerignore

.DS_Store
.vscode
.idea
